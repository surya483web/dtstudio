rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net: default-deny everything not explicitly allowed below.
    match /{document=**} {
      allow read, write: if false;
    }

    // Public site content (hero, about, portfolio, services, stats, reviews...).
    // Anyone can read it (it powers the public website); only a signed-in
    // admin account can write/update it from the Admin Panel.
    match /settings/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Booking / reservation inquiries submitted from the public Contact form.
    // Anyone can create a new inquiry, but only a signed-in admin can read
    // the list or update its status (so client-submitted details stay
    // private and can't be scraped or tampered with).
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
